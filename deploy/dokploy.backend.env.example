# Copy these values into the Dokploy backend environment.
# Never commit real secrets.

# Runtime
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# Supabase PostgreSQL (secret)
SPRING_DATASOURCE_URL=jdbc:postgresql://aws-1-eu-west-2.pooler.supabase.com:5432/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres.<project-ref>
SPRING_DATASOURCE_PASSWORD=<supabase-password>

# Flyway
FLYWAY_BASELINE_ON_MIGRATE=true
FLYWAY_BASELINE_VERSION=1
SPRING_FLYWAY_OUT_OF_ORDER=false
SPRING_FLYWAY_IGNORE_MIGRATION_PATTERNS=*:missing

# JWT (secret)
JWT_SECRET=<base64-64-byte-secret>
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# Public URLs and CORS
FRONTEND_BASE_URL=https://aura-ia.es
CORS_ALLOWED_ORIGINS=https://aura-ia.es,https://www.aura-ia.es
ADMIN_EMAILS=<admin-email-1>,<admin-email-2>

# Email / Resend SMTP (SMTP_PASSWORD is secret)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USERNAME=resend
SMTP_PASSWORD=<resend-api-key>
SMTP_AUTH=true
SMTP_STARTTLS=true
SMTP_FROM=AURA IA <no-reply@aura-ia.es>
EMAIL_ENABLED=true
EMAIL_AUTO_VERIFY_WHEN_DISABLED=false
EMAIL_VERIFICATION_TTL_HOURS=24
PASSWORD_RESET_TTL_MINUTES=30
RESEND_WEBHOOK_SECRET=<resend-webhook-secret>

# Stripe (secret key and webhook secret are secret)
STRIPE_SECRET_KEY=sk_live_<stripe-live-secret>
STRIPE_WEBHOOK_SECRET=whsec_<stripe-live-webhook-secret>
STRIPE_PRICE_ID_PERSONAL=price_<live-personal-price>
STRIPE_PRICE_ID_PREMIUM=price_<live-premium-price>
STRIPE_PORTAL_CONFIGURATION_ID=bpc_<live-portal-configuration>

# Gemini (secret)
AI_SERVICE_ENABLED=true
GEMINI_API_KEY=<google-ai-studio-api-key>
GEMINI_MODEL=gemini-flash-latest
AI_MAX_HISTORY_MESSAGES=12
AI_CHAT_RATE_LIMIT_CAPACITY=20
AI_CHAT_RATE_LIMIT_REFILL_MINUTES=5

# Cloudflare Turnstile (secret key is secret)
TURNSTILE_ENABLED=true
TURNSTILE_SITE_KEY=<turnstile-site-key>
TURNSTILE_SECRET_KEY=<turnstile-secret-key>
TURNSTILE_TIMEOUT_MS=4000

# Content encryption (secret)
CONTENT_ENCRYPTION_KEY=base64:<32-random-bytes-base64>
CONTENT_ENCRYPTION_REQUIRED=true

# Web Push (private key is secret)
WEB_PUSH_ENABLED=true
WEB_PUSH_VAPID_PUBLIC_KEY=<vapid-public-key>
WEB_PUSH_VAPID_PRIVATE_KEY=<vapid-private-key>
WEB_PUSH_SUBJECT=mailto:hola@aura-ia.es
WEB_PUSH_SCHEDULER_ENABLED=true
WEB_PUSH_DIARY_REMINDER_TIME=21:30
WEB_PUSH_SCHEDULER_FIXED_DELAY_MS=60000

# Google OAuth (client secret is secret)
GOOGLE_OAUTH_ENABLED=true
GOOGLE_OAUTH_CLIENT_ID=<google-oauth-client-id>
GOOGLE_OAUTH_CLIENT_SECRET=<google-oauth-client-secret>
GOOGLE_OAUTH_REDIRECT_URI=https://api.aura-ia.es/api/v1/auth/oauth/google/callback
GOOGLE_OAUTH_STATE_TTL_MINUTES=10
GOOGLE_OAUTH_EXCHANGE_CODE_TTL_MINUTES=5

# SOS SMS disabled in production unless Twilio is explicitly adopted.
SOS_SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Dev-only seed must stay disabled in production.
DEV_DEMO_USER_ENABLED=false
DEV_DEMO_USER_EMAIL=
DEV_DEMO_USER_PASSWORD=
